# OAuth 凭证配置
# 复制此文件为 .env 并填入真实值
# 构建时会自动从此文件读取（通过 direnv 或 build 脚本）

# GitHub OAuth App
GH_OAUTH_CLIENT_ID=Ov23li2hRBoUIkY83knT
GH_OAUTH_CLIENT_SECRET=your_github_client_secret_here

# Gitee OAuth App
GITEE_CLIENT_ID=your_gitee_client_id_here
GITEE_CLIENT_SECRET=your_gitee_client_secret_here

# Netlify OAuth App
NETLIFY_CLIENT_ID=your_netlify_client_id_here
NETLIFY_CLIENT_SECRET=your_netlify_client_secret_here

# Vercel OAuth App
VERCEL_CLIENT_ID=your_vercel_client_id_here
VERCEL_CLIENT_SECRET=your_vercel_client_secret_here
